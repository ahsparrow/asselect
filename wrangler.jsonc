{
  "name": "asselect",
  "compatibility_date": "2026-06-05",

  "assets": {
    "directory": "./dist"
   },

  "env": {
    "production": {
      "routes": [
        { "pattern": "asselect.uk", "custom_domain": true }
      ]
    },
    "staging": {
      "routes": [
        { "pattern": "staging.asselect.uk", "custom_domain": true } 
      ]
    }
  }
}
