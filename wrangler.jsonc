{
  "name": "asselect",
  "compatibility_date": "2026-06-05",

  "assets": {
    "directory": "./dist"
   },

  "routes": [
    {
      "pattern": "asselect.uk",
      "custom_domain": true
    },
    {
      "pattern": "www.asselect.uk",
      "custom_domain": true,
    }
  ],

  "env": {
    "staging": {
      "routes": [
        {
          "pattern": "staging.asselect.uk",
          "custom_domain": true
        } 
      ]
    }
  }
}
